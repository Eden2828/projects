# ===== Anthropic (Claude) =====
ANTHROPIC_API_KEY=sk-ant-...
# מודל ה-agent. ברירת מחדל: claude-opus-4-8 (אפשר claude-sonnet-4-6 לחיסכון)
ANTHROPIC_MODEL=claude-opus-4-8

# ===== Meta Marketing API (read-only) =====
META_ACCESS_TOKEN=
META_APP_ID=
META_APP_SECRET=
META_API_VERSION=v20.0
# קצב קריאות ל-Meta (שניות מינימום בין קריאות) ומספר ניסיונות חוזרים
META_MIN_SECONDS_BETWEEN_CALLS=1.0
META_MAX_RETRIES=4

# ===== שרת =====
PORT=8000
# מפתח לחתימת sessions (כל מחרוזת אקראית ארוכה)
SESSION_SECRET=change-me-to-a-long-random-string

# ===== סריקת התראות =====
# כל כמה דקות לרוץ סריקה אוטומטית של ההתראות
SCAN_INTERVAL_MINUTES=30
# חלון הזמן שעליו רצות רוב חוקי ההתראות
SCAN_DATE_PRESET=today
# הרצה אוטומטית של scheduler בעלייה (true/false)
SCHEDULER_ENABLED=true

# ===== כללי =====
CURRENCY=₪
