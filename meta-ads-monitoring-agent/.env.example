# =============================================================================
# Meta Ads Monitoring & QA Agent - Environment Configuration
# Copy this file to ".env" and fill in real values. NEVER commit the real .env.
# =============================================================================

# --- Meta Marketing API (READ-ONLY) -----------------------------------------
# The access token only needs the "ads_read" permission.
# DO NOT grant "ads_management" - this agent must never write to Meta Ads.
META_ACCESS_TOKEN=
META_APP_ID=
META_APP_SECRET=
# Graph API version used for all calls (e.g. v19.0, v20.0).
META_API_VERSION=v20.0

# --- Supabase ----------------------------------------------------------------
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# --- Anthropic Claude API ----------------------------------------------------
ANTHROPIC_API_KEY=
# Model used for report generation / issue explanation only.
ANTHROPIC_MODEL=claude-sonnet-4-6

# --- Scheduler ---------------------------------------------------------------
# How often the monitoring cycle runs, in minutes.
CHECK_INTERVAL_MINUTES=30

# --- Data sources & behavior -------------------------------------------------
# Where to load the client list from: "supabase" or "json".
CLIENTS_SOURCE=json
# Path to the local clients file (used when CLIENTS_SOURCE=json).
CLIENTS_FILE=clients.json
# Path to the QA thresholds/rules file.
RULES_FILE=rules.json
# Directory where Markdown/CSV reports are written.
REPORTS_DIR=reports

# --- Meta API rate limiting / retries ----------------------------------------
# Minimum seconds to wait between Meta API calls (simple client-side throttle).
META_MIN_SECONDS_BETWEEN_CALLS=1.0
# Max retry attempts for transient Meta API failures.
META_MAX_RETRIES=4

# --- Logging -----------------------------------------------------------------
# DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
# Set to "true" to emit logs as JSON (recommended for production log pipelines).
LOG_JSON=false

# --- Reporting toggles -------------------------------------------------------
# Whether to call Claude to generate the narrative daily report.
USE_CLAUDE_REPORT=true
# Export formats to write each run (comma separated): markdown,csv
EXPORT_FORMATS=markdown,csv
