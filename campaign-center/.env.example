# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Google Gemini AI
GEMINI_API_KEY=your-gemini-api-key

# Meta Marketing API
META_APP_ID=4457830191115452
META_APP_SECRET=your-meta-app-secret
META_ACCESS_TOKEN=your-long-lived-access-token

# Next.js
NEXTAUTH_SECRET=your-nextauth-secret-32-chars-min
NEXTAUTH_URL=https://thinkdigital.co.il/campaign-center

# Allowed CORS origin
ALLOWED_ORIGIN=https://thinkdigital.co.il

# Encryption key for storing tokens (32 bytes hex)
ENCRYPTION_KEY=your-32-byte-hex-encryption-key

# Webhook verification token
META_WEBHOOK_VERIFY_TOKEN=your-webhook-verify-token

# Feature flags
NEXT_PUBLIC_ENABLE_AI_ACTIONS=true
NEXT_PUBLIC_ENABLE_REPORTS=true
NEXT_PUBLIC_MAX_CLIENTS=150

# ============================================================
# AdPilot (Self-Serve, Agency-Grade Meta Ads — AI-Powered) — mounted at /app
# ============================================================

# AI provider — Anthropic Claude (used by POST /api/ai/generate-campaign).
# Get a key at https://console.anthropic.com/
AI_API_KEY=sk-ant-your-anthropic-api-key
# Optional model override (defaults to claude-opus-4-8)
AI_MODEL=claude-opus-4-8

# Meta Marketing API (OAuth for AdPilot business users).
# META_APP_ID / META_APP_SECRET are reused from the Campaign Center section above.
META_REDIRECT_URI=http://localhost:3000/api/meta/auth/callback
META_API_VERSION=v21.0

# Secret guarding the cron-ready optimization job (POST /api/jobs/daily-optimization).
# Send it as `Authorization: Bearer <CRON_SECRET>`.
CRON_SECRET=generate-a-long-random-string
